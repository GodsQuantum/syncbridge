# Copie en .env et adapte. Aucune valeur secrète requise par défaut.
TZ=Europe/Paris
SB_UID=1000
SB_GID=1000
# Dossiers scannés pour l'import (scripts, crontabs) — séparés par :
SB_IMPORT_PATHS=/import/scripts:/import/crontab

# Auth (OPTIONNEL) : par défaut le compte se crée au 1er lancement dans l'UI.
# Décommente pour imposer l'identifiant/mot de passe par l'environnement à la place
# (pas d'écran de création : on se connecte directement avec ces valeurs).
#SYNCBRIDGE_USER=arezki
#SYNCBRIDGE_PASSWORD=change-me
